{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next .next-dev out",
    "dev": "next dev",
    "dev:clean": "npm run clean && next dev",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "export": "next export",
    "start": "next start",
    "lint": "next lint",
    "deploy": "npm run build && gh-pages -d out"
  },
  "dependencies": {
    "next": "^15.5.9",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "eslint": "^9",
    "eslint-config-next": "15.1.3",
    "gh-pages": "^5.0.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1"
  }
}
